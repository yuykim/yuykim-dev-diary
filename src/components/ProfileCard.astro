---
import { sitePath } from "../lib/site";
---

<aside class="profile-card" aria-label="Profile character">
  <div class="profile-card__screen">
    <img
      src={sitePath("/images/profile/profile_img2.jpg")}
      alt="레서판다 자캐 프로필 이미지"
      loading="eager"
    />
  </div>
  <div class="profile-card__info">
    <span>PLAYER AVATAR</span>
    <strong>Red Panda Dev</strong>
    <p>Profile art by Margarita <a href="https://www.instagram.com/margarita.pics/">@margarita.pics</a>, used with permission.</p>
  </div>
</aside>
